# ============================================================
# 🔐 المتغيرات البيئية - Marine Security System
# ============================================================

# المفاتيح الأساسية (توليد تلقائي إذا لم تكن موجودة)
JWT_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=

# إعدادات الخادم
PORT=3443
NODE_ENV=development

# الأمان
SALT_ROUNDS=12
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3443

# SSL (للإنتاج)
SSL_ENABLED=false
SSL_KEY_PATH=/etc/ssl/private/server.key
SSL_CERT_PATH=/etc/ssl/certs/server.crt

# Redis (للتوسع)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
