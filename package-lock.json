// ==================== إنشاء مستخدم admin ====================
async function initializeAdmin() {
    try {
        // انتظر قليلاً للتأكد من اتصال قاعدة البيانات
        await new Promise(resolve => setTimeout(resolve, 3000));
        
        let adminExists = false;
        
        // البحث في قاعدة البيانات
        if (dbConnected && mongoose.connection.readyState === 1) {
            try {
                adminExists = await User.findOne({ name: 'admin' });
            } catch (err) {
                console.error('خطأ في البحث عن admin في DB:', err);
            }
        }
        
        // البحث في الذاكرة
        if (!adminExists) {
            adminExists = memoryUsers.find(u => u.name === 'admin');
        }
        
        if (!adminExists) {
            const adminData = {
                name: 'admin',
                pass: '1234',
                role: 'مسؤول',
                enabled: true
            };
            
            if (dbConnected && mongoose.connection.readyState === 1) {
                try {
                    await User.create(adminData);
                    console.log('✅ تم إنشاء مستخدم admin في قاعدة البيانات (admin / 1234)');
                } catch (err) {
                    console.error('خطأ في إنشاء admin في DB:', err);
                    memoryUsers.push({ ...adminData, _id: Date.now().toString() });
                    console.log('✅ تم إنشاء مستخدم admin في الذاكرة (admin / 1234)');
                }
            } else {
                memoryUsers.push({ ...adminData, _id: Date.now().toString() });
                console.log('✅ تم إنشاء مستخدم admin في الذاكرة (admin / 1234)');
            }
        } else {
            console.log('✅ مستخدم admin موجود بالفعل');
        }
    } catch (err) {
        console.error('❌ خطأ في إنشاء المستخدم admin:', err.message);
    }
}

