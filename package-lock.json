const express = require('express');
const mongoose = require('mongoose');
const session = require('express-session');
const path = require('path');
const http = require('http');
const socketIo = require('socket.io');
const cors = require('cors');

const app = express();
const server = http.createServer(app);
const io = socketIo(server);
const PORT = process.env.PORT || 3000;

// ==================== بيانات ثابتة للمستخدمين (تعمل دائماً) ====================
const DEFAULT_USERS = [
    { name: 'admin', pass: '1234', role: 'مسؤول' },
    { name: 'user', pass: '1234', role: 'محرر' },
    { name: 'viewer', pass: '1234', role: 'مشاهد' }
];

// بيانات تخزين مؤقتة (في حالة فشل قاعدة البيانات)
let memoryUsers = [...DEFAULT_USERS];
let memoryVessels = [];
let memoryTickets = [];
let memoryLogs = [];
let memoryLocations = [];

// ==================== الاتصال بقاعدة البيانات ====================
const MONGO_URI = process.env.MONGO_URI || 'mongodb+srv://marineUser:marineUser@cluster0.ajb5w1z.mongodb.net/marine_fleet?retryWrites=true&w=majority';

let dbConnected = false;

mongoose.connect(MONGO_URI, {
    useNewUrlParser: true,
    useUnifiedTopology: true,
    serverSelectionTimeoutMS: 5000,
})
.then(() => {
    dbConnected = true;
    console.log('✅ متصل بـ MongoDB بنجاح');
})
.catch(err => {
    dbConnected = false;
    console.error('⚠️ خطأ في الاتصال بقاعدة البيانات، سيتم استخدام البيانات الثابتة');
    console.error('❌', err.message);
});

// ==================== Middleware ====================
app.use(cors({ origin: ['http://localhost:3000', 'http://127.0.0.1:3000'], credentials: true }));
